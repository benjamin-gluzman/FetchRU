{
  "name": "FetchRU",
  "description": "Rutgers Course Watcher",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "./dist/popup.html",
    "default_icon": {
        "128": "./assets/icons/icon128.png",
        "48": "./assets/icons/icon48.png",
        "16": "./assets/icons/icon16.png"
    }
  },
  "icons": {
    "128": "./assets/icons/icon128.png",
    "48": "./assets/icons/icon48.png",
    "16": "./assets/icons/icon16.png"
  },
  "background": {
    "service_worker": "./dist/background.js"
  },
  "permissions": [
    "storage",
    "background",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://classes.rutgers.edu/*"
  ]
}