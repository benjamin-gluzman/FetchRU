{
  "name": "FetchRU",
  "description": "Rutgers Course Watcher",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "./dist/popup.html",
    "default_icon": "./assets/logo.png"
  },
  "background": {
    "service_worker": "./dist/background.js"
  },
  "permissions": [
    "storage",
    "background",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://classes.rutgers.edu/*"
  ]
}